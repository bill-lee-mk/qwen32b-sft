# 复制为 .env 并填入真实值，或直接 export 到 shell
# 请勿提交 .env 到 git

# === 评估 API（InceptBench）===
# 主配置（必填）
INCEPTBENCH_API_KEY=

# 第二套（可选，主配置失败时自动降级，URL 固定为 api.inceptbench.com）
EVALUATOR_TOKEN=

# === 生成 MCQ 用 API ===
# OpenRouter（默认推荐，聚合多家模型）
OPENROUTER_API_KEY=

# 其他模型直连（按需配置）
# FIREWORKS_API_KEY=
# DEEPSEEK_API_KEY=
# KIMI_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
